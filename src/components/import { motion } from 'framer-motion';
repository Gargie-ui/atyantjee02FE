          <span className="rounded-full bg-orange-500/10 px-3 py-1 text-[10px] font-black text-orange-600">
            {card.discount}
          </span>
        </div>

        {/* Title */}
        <h3 className="text-2xl font-black leading-tight tracking-tight text-[#0B0F2E]">
          {card.title}
        </h3>

        {/* Optional subtitle */}
        {card.subtitle && (
          <p className="mt-1 text-sm font-medium text-slate-500">{card.subtitle}</p>
        )}

        {/* Price row */}
        <div className="mt-3 flex items-baseline gap-2">
          <span className="text-4xl font-black text-[#0B0F2E]">₹{card.price}</span>
          {card.oldPrice && (
            <span className="text-lg font-bold line-through text-slate-400">₹{card.oldPrice}</span>
          )}
        </div>

        {/* Best For block */}
        <div className="mt-4 rounded-xl bg-slate-50 border border-slate-100 px-4 py-3.5">
          <span className="block text-[10px] font-black uppercase tracking-wider text-orange-600 mb-1">
