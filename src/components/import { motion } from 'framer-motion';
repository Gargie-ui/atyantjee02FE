          {card.features.map((feature) => (
            <div key={feature} className="flex items-start gap-2.5">
              <CheckCircle2 className={`h-4 w-4 shrink-0 mt-0.5 ${theme.checkColor}`} />
              <span className="text-sm font-medium text-slate-700 leading-snug">{feature}</span>
            </div>
          ))}
        </div>

        {/* Bonus section */}
        {card.bonusItems && card.bonusItems.length > 0 && (
          <div className="mt-5 rounded-2xl bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-100 p-4">
            <div className="flex items-center gap-2 mb-3">
