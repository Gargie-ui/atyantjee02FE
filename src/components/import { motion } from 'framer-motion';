        {/* Inline badge — only when not floating */}
        {!card.badgeFloating && (
          <div className="mb-4 inline-flex">
            <span className="rounded-full bg-orange-500/10 px-4 py-1 text-[11px] font-black uppercase tracking-[0.14em] text-orange-600">
              {card.badge}
            </span>
          </div>
        )}

        {/* Discount pill */}
